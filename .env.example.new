# Telegram Bot Configuration
TG_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TG_GROUP_ID=-1001234567890

# Data Directory
DATA_DIR=./data

# ===== AI CONFIGURATION (GROQ) =====
# Enable/Disable AI features
AI_ENABLED=true

# AI Provider (groq, openai, etc.)
AI_PROVIDER=groq

# Groq API Key (get from https://console.groq.com/keys)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== AUTO-REPLY SETTINGS =====
# Enable auto-reply feature
AUTO_REPLY_ENABLED=true

# Delay before responding (milliseconds) - to seem more natural
AUTO_REPLY_DELAY_MS=1000

# Max context messages to remember
AUTO_REPLY_MAX_CONTEXT=10

# Response style: friendly, professional, casual
AUTO_REPLY_STYLE=friendly
