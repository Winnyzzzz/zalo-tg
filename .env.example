# Telegram Bot token from @BotFather
TG_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram supergroup ID (negative integer, e.g. -1001234567890)
TG_GROUP_ID=-1001234567890

# Directory for persistent data (topics.json, credentials.json)
# Defaults to ./data if omitted
DATA_DIR=./data

# ============================================
# GROQ AI CONFIGURATION
# ============================================

# Enable AI auto-reply feature
AI_ENABLED=true

# Groq API key (get from https://console.groq.com/keys)
GROQ_API_KEY=

# Groq model (default: mixtral-8x7b-32768)
# Other options: llama2-70b, gemma-7b-it, etc
GROQ_MODEL=mixtral-8x7b-32768

# AI response style: friendly | professional | casual | creative
AI_STYLE=friendly

# ============================================
# AUTO-REPLY SETTINGS
# ============================================

# Enable auto-reply feature
AUTO_REPLY_ENABLED=true

# Delay before sending AI response (in milliseconds)
# Recommended: 1000 (1 second) to look more natural
AUTO_REPLY_DELAY_MS=1000

# Respond to mentions (@bot)
AUTO_REPLY_RESPOND_TO_MENTIONS=true

# Respond to questions (messages with ?)
AUTO_REPLY_RESPOND_TO_QUESTIONS=true

# Respond to random messages
AUTO_REPLY_RESPOND_TO_RANDOM=true

# Chance to respond to random messages (0.0 - 1.0)
# Example: 0.3 = 30% chance to respond
AUTO_REPLY_RANDOM_CHANCE=0.3
